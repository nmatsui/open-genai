# Open GENAI: ローカル実行用のフロントエンド環境変数
# コピー: cp .env.example .env
# これらは Vite ビルド時に import.meta.env として埋め込まれる。

# --- API 接続先（ブラウザから見たバックエンド） ---
# docker compose 利用時は nginx 経由の /api を指定（ポートは PROXY_HTTP_PORT に合わせる）
VITE_APP_API_ENDPOINT=http://localhost/api
VITE_APP_TEAM_ACCESS_CONTROL_API_ENDPOINT=http://localhost/api

# --- 利用可能なモデル（Ollama のモデル名と一致させる） ---
VITE_APP_MODEL_IDS=["gpt-oss:20b","gemma3:27b"]
VITE_APP_IMAGE_MODEL_IDS=[]
VITE_APP_ENDPOINT_NAMES=[]

# --- 認証（ローカルではダミー化済み。値は使用されない） ---
VITE_APP_REGION=local
VITE_APP_MODEL_REGION=local
VITE_APP_USER_POOL_ID=local_dummy
VITE_APP_USER_POOL_CLIENT_ID=local_dummy
VITE_APP_IDENTITY_POOL_ID=local_dummy
VITE_APP_PREDICT_STREAM_FUNCTION_ARN=local_dummy
VITE_APP_SELF_SIGN_UP_ENABLED=false
VITE_APP_SAMLAUTH_ENABLED=false
VITE_APP_SAML_COGNITO_DOMAIN_NAME=local_dummy
VITE_APP_SAML_COGNITO_FEDERATED_IDENTITY_PRIMARY_PROVIDER_NAME=local_dummy
VITE_APP_SAML_COGNITO_FEDERATED_IDENTITY_ADDITIONAL_PROVIDER_NAMES=

# --- 機能フラグ ---
# 画像生成はローカル(Ollama)では非対応のため非表示にする
VITE_APP_HIDDEN_USE_CASES={"image":true}
VITE_APP_GOVAIS_FOR_HOMEPAGE=[]
VITE_APP_TOP_CHAT_SYSTEM_PROMPT=
VITE_APP_TOP_CHAT_SYSTEM_PROMPT_TITLE=
VITE_APP_ENV=local
VITE_APP_VERSION=open-genai
