# Open GENAI 本番用の設定（コピーして .env.prod として使用）
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up --build
#
# 方針: ユーザ公開は proxy の 80/443 のみ。フロントの API 参照は相対 /api。

# === 必須: 公開URL（proxy が終端する https のベースURL。末尾スラッシュ無し）===
# 例: https://genai.example.lg.jp
PUBLIC_URL=https://genai.example.lg.jp

# Vite(dev server) に許可させる公開ホスト名（true で全許可、または PUBLIC_URL のホスト）
# 例: genai.example.lg.jp
VITE_ALLOWED_HOSTS=genai.example.lg.jp

# === 認証・鍵（本番では必ず変更）===
APP_JWT_SECRET=please-change-to-a-long-random-secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=please-change-me

# === LLM 接続（OpenAI 互換）===
OLLAMA_BASE_URL=http://host.docker.internal:11434
# OPENAI_BASE_URL=
# OPENAI_API_KEY=ollama
DEFAULT_MODEL=qwen2.5:7b

# === RAG / 監査 / 各 AI アプリ ===
EMBED_MODEL=mxbai-embed-large
RAG_MODEL=gpt-oss:20b
RAG_API_KEY=change-me-local-rag-key
AUDIT_ENABLED=true
AUDIT_STORE_CONTENT=true
AUDIT_MAX_CONTENT_CHARS=8000
AUDIT_RETENTION_DAYS=1825
# LEGACY_CHAT_OWNER=

# --- 文字起こし / 画像生成 ---
WHISPER_MODEL=medium
WHISPER_COMPUTE=int8
SD_API_URL=http://host.docker.internal:7860

# === 成果物ファイル配信（自前 S3 互換: SeaweedFS）===
S3_ENDPOINT_URL=http://seaweedfs:8333
# 必須: 利用者がインターネットから取得する公開URL（TLS 付きの配信ドメイン）
#   例: https://files.example.lg.jp
S3_PUBLIC_ENDPOINT=https://files.example.lg.jp
S3_BUCKET=open-genai
# seaweedfs/s3.config.json と一致させる（本番用に必ず変更）
S3_ACCESS_KEY=please-change-access-key
S3_SECRET_KEY=please-change-secret-key
S3_PRESIGN_EXPIRY=86400

# ============================================================================
# 併せて必要な「設定ファイル」側の変更（このファイルでは反映されない項目）
# ============================================================================
# 1) フロントの API 参照を相対パスにする（genai-web 無改修・.env のみ）:
#    genai-web/packages/web/.env に以下を設定
#      VITE_APP_API_ENDPOINT=/api
#      VITE_APP_TEAM_ACCESS_CONTROL_API_ENDPOINT=/api
#
# 2) Keycloak の SAML クライアント(SP)登録を公開URLに合わせる:
#    keycloak/import/realm-open-genai.json の以下を PUBLIC_URL に置換
#    （初回 import 前に編集、または admin コンソールで既存を更新）
#      clientId:                             {PUBLIC_URL}/api/auth/saml/metadata
#      redirectUris:                         {PUBLIC_URL}/api/auth/saml/acs, {PUBLIC_URL}/*
#      saml_assertion_consumer_url_post:     {PUBLIC_URL}/api/auth/saml/acs
#      saml_single_logout_service_url_redirect: {PUBLIC_URL}/api/auth/saml/sls
#
# 3) 証明書を proxy/certs/{fullchain.pem,privkey.pem} に配置
#    （閉域検証は ./proxy/certs/generate-selfsigned.sh <ホスト名>）
