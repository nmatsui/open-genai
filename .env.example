# Open GENAI: docker compose 用の設定（コピーして .env として使用）

# ホストで Ollama を動かす場合（推奨, macOS は Metal GPU が使えて高速）
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama もコンテナで動かす場合（docker compose --profile ollama up）は以下に変更
# OLLAMA_BASE_URL=http://ollama:11434

# LLM は OpenAI 互換 API 経由で呼び出します。
# 未指定なら OLLAMA_BASE_URL + /v1 を使用します。
# vLLM / LM Studio / OpenAI 等に向ける場合のみ設定してください。
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_API_KEY=ollama

# 既定で利用するモデル（フロントでモデル未選択時に使用）
DEFAULT_MODEL=qwen2.5:7b

# --- RAG「AI アプリ」設定 ---
# 埋め込みモデル（ollama pull mxbai-embed-large で取得）
EMBED_MODEL=mxbai-embed-large
# RAG 回答生成に使うモデル
RAG_MODEL=gpt-oss:20b
# AI アプリ呼び出し用 API キー（ローカル任意値）
RAG_API_KEY=local-rag-key

# --- 監査ログ参照(Audit) AI アプリ（管理者限定）---
# backend からのプロキシ先（通常は変更不要）
AUDIT_APP_URL=http://audit-app:8005/invoke

# --- 文字起こし(Whisper) AI アプリ ---
WHISPER_MODEL=medium        # small / medium / large-v3
WHISPER_COMPUTE=int8

# --- 画像生成(Stable Diffusion) AI アプリ ---
# ホストで動く AUTOMATIC1111 互換 SD サーバの URL
SD_API_URL=http://host.docker.internal:7860

# --- 成果物ファイル配信用オブジェクトストレージ（自前 S3 互換: SeaweedFS）---
# AI アプリ（Dify等）が生成したファイルを自前ストレージへ再ホストし署名付きURLで配信。
# dev 既定は同梱の SeaweedFS。接続先を変えれば MinIO 等にも差し替え可能。
S3_ENDPOINT_URL=http://seaweedfs:8333
# 署名付きURL生成に使う公開エンドポイント（dev はホストから見える localhost:8333）
S3_PUBLIC_ENDPOINT=http://localhost:8333
S3_BUCKET=open-genai
# 認証情報（seaweedfs/s3.config.json と一致させること。本番は必ず変更）
S3_ACCESS_KEY=opengenai
S3_SECRET_KEY=opengenai-secret
# 署名付きURLの有効期限（秒。既定24時間）
S3_PRESIGN_EXPIRY=86400

# --- Dify 連携 AI アプリ ---
# Dify(ワークフロー/チャットフロー)を「AI アプリ」として登録するための汎用プロキシ。
# アプリ登録時の endpoint に使う値（通常は変更不要）。
DIFY_APP_URL=http://dify-app:8004/invoke
# 既定の Dify 接続先(base_url, 末尾 /v1)。任意。
# 各 AI アプリの「設定(config)」で個別に指定する場合は空のままで構いません。
# 例: DIFY_BASE_URL=http://host.docker.internal/v1
# DIFY_BASE_URL=

# --- SAML 認証（backend = SAML SP / Keycloak = SAML IdP）---
# アプリ JWT 署名鍵（本番では十分長いランダム値に変更すること）
APP_JWT_SECRET=change-me-open-genai-secret
# ログイン後に戻るフロントエンド URL
FRONTEND_URL=http://localhost:5173
# Keycloak 管理者（http://localhost:8080 の admin console 用）
# ※ 利用者一括管理(usermgmt-app) はこの管理者資格情報で Keycloak Admin API を呼ぶ
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# usermgmt-app から見た Keycloak の内部URL（dev 既定。prod は /kc を含める）
# KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_REALM=open-genai

# --- 監査ログ（利用状況/内容ログ・8-(1) 対応）---
# 監査ログ機能の有効化
AUDIT_ENABLED=true
# 監査ログ DB（チャット履歴とは独立、append-only）
AUDIT_DB_PATH=/data/audit.db
# 入出力の内容を保存するか（false の場合は文字数のみ記録）
AUDIT_STORE_CONTENT=true
# 内容保存の上限文字数
AUDIT_MAX_CONTENT_CHARS=8000
# 保持日数（最低 1095=3年。既定 1825=5年。3年未満を指定しても 1095 に切り上げ）
AUDIT_RETENTION_DAYS=1825

# --- チャット履歴のユーザー別分離（6-(8) 対応）---
# userId 列が無い既存チャットの移管先（メール/sub）。空なら移管せず不可視化。
# LEGACY_CHAT_OWNER=
